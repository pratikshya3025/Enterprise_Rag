# ============================================================
# EnterpriseRAG — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to Git. Only commit .env.example.
# ============================================================

# --- Google Gemini API ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key

# --- Cohere API (optional) ---
# Only needed if you switch from BAAI/bge-reranker-base to Cohere Rerank.
# Get your key at: https://dashboard.cohere.com/api-keys
# COHERE_API_KEY=your_cohere_api_key_here
